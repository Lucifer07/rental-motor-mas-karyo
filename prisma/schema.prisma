generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Motorcycle {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  image       String
  category    String
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  prices      Price[]
}

model Price {
  id           String     @id @default(cuid())
  motorcycleId String
  category     String
  price12h     Int
  price24h     Int
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  motorcycle   Motorcycle @relation(fields: [motorcycleId], references: [id], onDelete: Cascade)

  @@unique([motorcycleId, category])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String   @default("Customer")
  avatar    String
  rating    Float    @default(5.0)
  comment   String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Client {
  id      String @id @default(cuid())
  name    String
  logo    String
  order   Int    @default(0)
  isActive Boolean @default(true)
}

model Advantage {
  id          String @id @default(cuid())
  title       String
  description String
  icon        String
  order       Int    @default(0)
  isActive    Boolean @default(true)
}

model Promo {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TouristInfo {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
